# Telegram: получить у @BotFather
BOT_TOKEN=

# Режим по умолчанию: short | detailed
DEFAULT_MODE=short

# Уровень: easy | academic | exam
DEFAULT_LEVEL=easy

# URL мок-сервисов (после запуска uvicorn на портах 8001–8003)
ANSWER_SERVICE_URL=http://127.0.0.1:8001
VOICE_SERVICE_URL=http://127.0.0.1:8002
BATTLE_SERVICE_URL=http://127.0.0.1:8003

# Voice service: ускорение готового WAV после TTS (1.0 = без изменений, 1.4 = на 40% короче)
VOICE_TIME_STRETCH_RATE=1.4
